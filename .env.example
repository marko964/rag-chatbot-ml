# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cal.com (optional — for meeting booking)
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_BOOKING_URL=https://cal.com/yourname/30min

# Admin endpoint auth
ADMIN_API_KEY=change-me-to-something-secret

# CORS — lock to your domain in production, e.g. https://yourwebsite.com
ALLOWED_ORIGINS=*

# Set to False in production (hides /docs and /redoc)
DEBUG=False
